# CarbonTrinityAudioAPIConfig.cmake
# Configuration file for the CarbonTrinityAudioAPI interface library

if(NOT TARGET CarbonTrinityAudioAPI)
    add_library(CarbonTrinityAudioAPI INTERFACE IMPORTED)
    
    # Set the include directory for the target
    set_target_properties(CarbonTrinityAudioAPI PROPERTIES
        INTERFACE_INCLUDE_DIRECTORIES "${CMAKE_CURRENT_LIST_DIR}/include"
    )
endif()